datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  username  String   @unique
  email     String   @unique
  password  String
  rol       String   @default("CLIENTE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}